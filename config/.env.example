# DeepSeek API Config
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Proxy & SSL
# Example: http://127.0.0.1:7890
PROXY_URL=
# false means verify=False (insecure, for proxy troubleshooting only)
SSL_VERIFY=false

# Legacy compatibility (optional)
GLOBAL_API_KEY=

# Runtime
MAX_RETRIES=3
REQUEST_TIMEOUT=30

# Data paths
RAW_DATA_PATH=data/raw/sycophancy_questions.csv
PROCESSED_DATA_PATH=data/processed/sycophancy_ready_to_test.csv
RESULTS_PATH=data/results/judgment_results.csv

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/alignment_tax.log
