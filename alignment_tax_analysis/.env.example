# DeepSeek API 配置
GLOBAL_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 实验参数
DEEPSEEK_MODEL=deepseek-chat
MAX_RETRIES=3
REQUEST_TIMEOUT=60

# 数据路径
RAW_DATA_PATH=data/raw/sycophancy_questions.csv
PROCESSED_DATA_PATH=data/processed/sycophancy_ready_to_test.csv
RESULTS_PATH=data/results/judgment_results.csv

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/alignment_tax.log
